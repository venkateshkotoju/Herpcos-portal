# HerPCOS Portal — Environment Variables
# Copy this file to .env.local and fill in your values
# On Vercel: add these under Project → Settings → Environment Variables

# ─── AI Chat (REQUIRED) ────────────────────────────────────────────────────────
# Powers the /chat AI assistant. Get your key at https://console.anthropic.com
# Without this, /api/chat returns 500 and the chatbot does not work.
ANTHROPIC_API_KEY=

# ─── Analytics (OPTIONAL) ──────────────────────────────────────────────────────
# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX)
# Leave blank to disable. Get from https://analytics.google.com
NEXT_PUBLIC_GA4_ID=

# ─── Email / Newsletter (OPTIONAL) ─────────────────────────────────────────────
# Wire up one of these to deliver contact form submissions and newsletter sign-ups.
#
# Option A: Resend (recommended — free tier: 100 emails/day)
#   https://resend.com
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# CONTACT_TO_EMAIL=your@email.com
#
# Option B: Mailchimp
#   https://mailchimp.com → Account → Extras → API Keys
# MAILCHIMP_API_KEY=xxxxxxxxxxxxxxxxxxxx-us1
# MAILCHIMP_LIST_ID=xxxxxxxxxxxx
#
# Option C: ConvertKit
#   https://app.convertkit.com/account/edit
# CONVERTKIT_API_KEY=xxxxxxxxxxxxxxxxxxxx
# CONVERTKIT_FORM_ID=xxxxxxxxxxxx
